# Local development port. Vercel ignores this, but local node/Express runs need it.
PORT=

# Supabase project URL, for example https://xyzcompany.supabase.co
SUPABASE_URL=

# Backend-only service role key. Store only in Vercel server-side environment variables.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase anon key used for login/session exchange flows.
SUPABASE_ANON_KEY=

# Production frontend origin allowed by CORS, for example https://app.example.com
FRONTEND_URL=

# Secret used once to create the first admin through /api/auth/register-admin
ADMIN_SETUP_KEY=

# Runtime environment: development, test, or production
NODE_ENV=

# Optional global rate-limit window in milliseconds. Default is 900000 (15 minutes).
RATE_LIMIT_WINDOW_MS=

# Optional default authenticated rate limit if a role-specific rule does not match. Default is 100.
RATE_LIMIT_MAX=

# Optional outbound webhook timeout in milliseconds. Default is 5000.
WEBHOOK_TIMEOUT_MS=

# Optional logical clinic identifier embedded in outbound webhooks. Default is default-clinic.
CLINIC_ID=

# Optional. Vercel populates this automatically for preview/production domains.
VERCEL_URL=
