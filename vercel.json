{
  "version": 2,
  "functions": {
    "src/index.js": {
      "memory": 512,
      "maxDuration": 30,
      "regions": ["syd1"]
    }
  },
  "builds": [
    {
      "src": "src/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "src/index.js"
    }
  ]
}
